{
  "name": "custom-oauth-task-manager",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run build:client && node src/index.js",
    "start:oauth": "node src/oauth/server.js",
    "start:app": "node src/app/server.js",
    "dev:client": "vite --config client/vite.config.js",
    "build:client": "vite build --config client/vite.config.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mmmagic": "^0.5.3",
    "multer": "^2.0.2",
    "nanoid": "^4.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.2.0"
  }
}
